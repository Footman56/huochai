# Kibana 仪表板配置
# 通过 Dev Tools 导入或使用 Kibana API

# ==================== 索引模式 ====================
# 创建索引模式: huochai-auth-*

# ==================== 发现页面保存的搜索 ====================

# 1. 登录日志搜索
{
  "title": "登录日志",
  "description": "查看所有登录相关的日志",
  "kibanaSavedObjectMeta": {
    "searchSourceJSON": {
      "index": "huochai-auth-*",
      "query": {
        "match": {
          "log_message": "登录"
        }
      },
      "filter": []
    }
  }
}

# 2. 错误日志搜索
{
  "title": "错误日志",
  "description": "查看所有错误级别的日志",
  "kibanaSavedObjectMeta": {
    "searchSourceJSON": {
      "index": "huochai-auth-*",
      "query": {
        "match": {
          "level": "error"
        }
      }
    }
  }
}

# 3. 按TraceId查询
{
  "title": "链路追踪查询",
  "description": "根据TraceId查询完整请求链路",
  "kibanaSavedObjectMeta": {
    "searchSourceJSON": {
      "index": "huochai-auth-*",
      "query": {
        "wildcard": {
          "traceId": "*"
        }
      }
    }
  }
}

# ==================== 可视化图表 ====================

# 1. 日志级别分布饼图
{
  "title": "日志级别分布",
  "type": "pie",
  "aggs": [
    {
      "id": "1",
      "type": "count",
      "schema": "metric"
    },
    {
      "id": "2",
      "type": "terms",
      "schema": "segment",
      "params": {
        "field": "level",
        "size": 10
      }
    }
  ]
}

# 2. 每小时日志数量趋势
{
  "title": "日志趋势",
  "type": "line",
  "aggs": [
    {
      "id": "1",
      "type": "count",
      "schema": "metric"
    },
    {
      "id": "2",
      "type": "date_histogram",
      "schema": "segment",
      "params": {
        "field": "@timestamp",
        "interval": "hour"
      }
    }
  ]
}

# 3. 登录成功/失败统计
{
  "title": "登录统计",
  "type": "bar",
  "aggs": [
    {
      "id": "1",
      "type": "count",
      "schema": "metric"
    },
    {
      "id": "2",
      "type": "filters",
      "schema": "segment",
      "params": {
        "filters": [
          {
            "input": {
              "query": "登录成功"
            },
            "label": "成功"
          },
          {
            "input": {
              "query": "登录失败"
            },
            "label": "失败"
          }
        ]
      }
    }
  ]
}

# 4. 用户活跃度TOP10
{
  "title": "活跃用户TOP10",
  "type": "table",
  "aggs": [
    {
      "id": "1",
      "type": "count",
      "schema": "metric"
    },
    {
      "id": "2",
      "type": "terms",
      "schema": "bucket",
      "params": {
        "field": "username",
        "size": 10,
        "orderAgg": {
          "id": "1",
          "type": "count"
        },
        "order": "desc"
      }
    }
  ]
}

