# ==================== 告警规则 ====================
# 需要配合 Kibana Alerting 功能使用

# 1. 登录失败次数告警
{
  "name": "登录失败告警",
  "rule_type_id": ".es-query",
  "schedule": {
    "interval": "5m"
  },
  "actions": [
    {
      "id": "webhook-action",
      "params": {
        "message": "5分钟内登录失败次数超过阈值"
      }
    }
  ],
  "params": {
    "index": ["huochai-auth-*"],
    "esQuery": {
      "query": {
        "bool": {
          "must": [
            {
              "match": {
                "log_message": "登录失败"
              }
            },
            {
              "range": {
                "@timestamp": {
                  "gte": "now-5m"
                }
              }
            }
          ]
        }
      }
    },
    "threshold": 10
  }
}

# 2. 错误日志告警
{
  "name": "错误日志告警",
  "rule_type_id": ".es-query",
  "schedule": {
    "interval": "1m"
  },
  "actions": [
    {
      "id": "webhook-action",
      "params": {
        "message": "检测到错误日志"
      }
    }
  ],
  "params": {
    "index": ["huochai-auth-*"],
    "esQuery": {
      "query": {
        "match": {
          "level": "error"
        }
      }
    },
    "threshold": 5
  }
}